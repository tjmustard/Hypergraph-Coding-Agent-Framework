# --- Hypergraph Coding Agent Framework Standard Ignores ---

# Framework: Active specifications and unverified outputs (Project-specific)
# We preserve the directory structure via .gitkeep, but ignore the actual files.
spec/active/*
!spec/active/.gitkeep
spec/archive/*
!spec/archive/.gitkeep
spec/compiled/*
!spec/compiled/.gitkeep

# Tests: Candidate outputs and fixtures should never be committed to the master template
tests/candidate_outputs/*
!tests/candidate_outputs/.gitkeep
tests/fixtures/*
!tests/fixtures/.gitkeep

# Python: Standard environment and cache ignores
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env

# OS-specific
.DS_Store
Thumbs.db

# Gemini CLI / Agent-specific temporary files
.gemini/tmp/
*.log
.README.md.swp
.README.md.swp
*.swp

# Temp files and folders
tmp/
.antigravitycli/f2c8e969-053f-4704-b288-7b6eb7cbbf76.json
